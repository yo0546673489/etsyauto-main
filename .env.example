# =============================================================================
# ETSY AUTOMATION PLATFORM - ENVIRONMENT CONFIGURATION
# =============================================================================

# =============================================================================
# DATABASE
# =============================================================================
DB_PASSWORD=postgres_secure_password_change_me
DATABASE_URL=postgresql://postgres:${DB_PASSWORD}@db:5432/etsy_platform
TEST_DATABASE_URL=postgresql://postgres:${DB_PASSWORD}@db:5432/etsy_platform

# =============================================================================
# APPLICATION
# =============================================================================
ENVIRONMENT=development
DEBUG=true

# Frontend API URL
# Development: http://localhost:8080
# Production: https://yourdomain.com (or empty for relative URLs)
NEXT_PUBLIC_API_URL=http://localhost:8080
API_INTERNAL_URL=http://api:8080
INTERNAL_API_SECRET=replace_with_random_internal_secret

# CORS Origins (comma-separated or JSON array)
CORS_ORIGINS=["http://localhost:3000"]

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================

# JWT Keys (generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ISSUER=etsy-automation-platform
JWT_AUDIENCE=etsy-automation-api

# NextAuth (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=your_nextauth_secret_change_me
NEXTAUTH_URL=http://localhost:3000

# Token Encryption (generate with: openssl rand -base64 32)
ENCRYPTION_KEY=

# Password Policy
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=30
REMEMBER_ME_TTL_DAYS=30

# Super-admin portal (http://localhost:3002) — min 16 characters; must match API
ADMIN_PORTAL_SECRET=

# =============================================================================
# OAUTH PROVIDERS
# =============================================================================

# Etsy API (get from https://www.etsy.com/developers/your-apps)
ETSY_CLIENT_ID=
ETSY_CLIENT_SECRET=
ETSY_REDIRECT_URI=http://localhost:3000/oauth/etsy/callback

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google

# =============================================================================
# EMAIL SERVICES
# =============================================================================

# Resend (recommended)
RESEND_API_KEY=
USE_RESEND=true
EMAIL_FROM=noreply@yourdomain.com

# SMTP (alternative to Resend)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Etsy Automation Platform

# Email Configuration
EMAIL_VERIFICATION_REQUIRED=true
VERIFICATION_TOKEN_EXPIRY_HOURS=24
RESET_TOKEN_EXPIRY_HOURS=1
FRONTEND_URL=http://localhost:3000

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================
SENTRY_DSN=
GRAFANA_PASSWORD=admin

# =============================================================================
# RATE LIMITING
# =============================================================================
# Per shop rate limits
ETSY_RATE_LIMIT_CAPACITY=100
ETSY_RATE_LIMIT_REFILL_PER_SEC=0.5

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# =============================================================================
# STORAGE (optional - for image uploads)
# =============================================================================
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# AdsPower (browser profiles for messaging automation)
ADSPOWER_BASE_URL=http://127.0.0.1:50325
ADSPOWER_API_KEY=replace_with_adspower_api_key

# =============================================================================
# PRODUCTION NOTES
# =============================================================================
# 1. Generate strong random values for all secrets
# 2. Set ENVIRONMENT=production in production
# 3. Set DEBUG=false in production
# 4. Update all URLs to use your production domain
# 5. Enable EMAIL_VERIFICATION_REQUIRED=true
# 6. Set up SENTRY_DSN for error tracking
# 7. Configure S3 for production image storage
