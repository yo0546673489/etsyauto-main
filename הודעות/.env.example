# Database
DATABASE_URL=postgresql://etsy_user:etsy_pass@localhost:5432/etsy_messages

# Redis
REDIS_URL=redis://localhost:6379

# AdsPower Local API
ADSPOWER_API_URL=http://local.adspower.net:50325

# Gmail IMAP (מייל מרכזי שאליו מועברים כל מיילי החנויות)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=YOUR_CENTRAL_EMAIL@gmail.com
IMAP_PASSWORD=YOUR_APP_PASSWORD_HERE

# API Server
API_PORT=3500
API_HOST=0.0.0.0

# Frontend
FRONTEND_URL=http://localhost:3501

# Debug
DEBUG=true
