# Copy to .env.local and adjust. Used when running the web app locally (e.g. npm run dev).
# Leave unset when running inside Docker; the container gets API_INTERNAL_URL from docker-compose.

# Backend URL for middleware proxy (required for local dev; "api" hostname only works inside Docker)
API_INTERNAL_URL=http://localhost:8080

# Optional: Google OAuth client ID (must match backend config)
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
